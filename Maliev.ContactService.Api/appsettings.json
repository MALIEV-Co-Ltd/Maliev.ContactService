{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "None",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore.Watch": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Jwt": {
      "Authority": "https://iam.maliev.io/realms/maliev",
      "Audience": "contact-service"
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379",
    "ContactDbContext": "Host=localhost;Database=contactdb;Username=postgres;Password=password"
  },
  "Cache": {
    "MaxCacheSize": 1000,
    "DefaultExpirationMinutes": 5
  },
  "RateLimiting": {
    "FixedWindow": {
      "PermitLimit": 10,
      "Window": "01:00:00",
      "QueueLimit": 0
    },
    "GlobalFixedWindow": {
      "PermitLimit": 100,
      "Window": "01:00:00",
      "QueueLimit": 0
    }
  },
  "IAM": {
    "ServiceAccountToken": ""
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 262144000
    }
  }
}